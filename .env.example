# =============================================================================
# Flight Tracker — Environment Variables
# Copy this file to .env.local and fill in what you need.
# =============================================================================

# -----------------------------------------------------------------------------
# FLIGHT DATA (pick one provider)
# -----------------------------------------------------------------------------

# Which ADS-B provider to use: adsb.fi | airplanes.live | mock
# DEFAULT: adsb.fi — FREE, no API key needed. Recommended for V1.
FLIGHT_PROVIDER=adsb.fi

# Force mock/sample data (useful for UI dev without network)
USE_MOCK_FLIGHTS=false

# Only needed if you switch away from adsb.fi:
#
# airplanes.live — set FLIGHT_PROVIDER=airplanes.live
#   Sign up at https://airplanes.live and request API access if required.
#   Some endpoints work without a key; if yours needs auth, set:
# FLIGHT_API_KEY=
#
# ADS-B Exchange (paid commercial API — NOT needed for V1)
#   https://www.adsbexchange.com/products/enterprise-excel/
#   If you ever wire this up as a custom provider:
# ADSBEXCHANGE_API_KEY=

# -----------------------------------------------------------------------------
# ZIP / GEOCODING (optional — US ZIP works free without any key)
# -----------------------------------------------------------------------------

# Default geocoder: Zippopotam.us (free, US 5-digit ZIP, no key)
# Only set these if you want Google Geocoding instead:
# GEOCODING_PROVIDER=google
# GOOGLE_GEOCODING_API_KEY=
#   Get one at: https://console.cloud.google.com/apis/credentials
#   Enable "Geocoding API" on your Google Cloud project.
#   Free tier: ~10,000 lookups/month — more than enough for personal use.

# -----------------------------------------------------------------------------
# SKY MAP THEME (Google Maps overlay)
# -----------------------------------------------------------------------------

# Required for the Sky Map display theme:
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
#   Get one at: https://console.cloud.google.com/apis/credentials
#   Enable "Maps JavaScript API" on your Google Cloud project.
#   Restrict the key to your domain in production.
