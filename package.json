{
  "name": "flight-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "npm run build:legacy-led && next dev -H 0.0.0.0",
