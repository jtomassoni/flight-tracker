# Sky Map theme — enable Maps JavaScript API in Google Cloud:
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Shared display settings (theme, ZIP, filters) and airline logos via Vercel Blob —
# syncs across devices when local and prod use the same store. On Vercel,
# BLOB_STORE_ID is set automatically when you attach a Blob store; locally run
# `vercel env pull`. Without either var, dev falls back to data/ on this machine.
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=
